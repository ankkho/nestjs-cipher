# Example Configuration — Use ConfigService to load all environment variables
# Copy to .env and customize with your values

# Provider: LOCAL (development) or GCP_KMS (production)
CIPHER_PROVIDER=LOCAL

# GCP KMS Configuration (required only if CIPHER_PROVIDER=GCP_KMS)
# Credentials are automatically detected via Application Default Credentials (ADC):
# - Set GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json OR
# - Run: gcloud auth application-default login OR
# - Use runtime service account (Cloud Run, GKE, Compute Engine)

GCP_KMS_PROJECT_ID=my-project-123
GCP_KMS_LOCATION=us-central1
GCP_KMS_KEY_RING=pii-ring
